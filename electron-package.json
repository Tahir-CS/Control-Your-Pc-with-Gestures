{
  "name": "opsghost-electron",
  "version": "1.0.0",
  "description": "Hands-free voice and gesture controlled desktop automation agent",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "electron .",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "@mediapipe/tasks-vision": "^0.10.32",
    "robotjs": "^0.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.opsghost.app",
    "productName": "OpsGhost",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  }
