# OpsGhost Environment Configuration

# Get your Gemini API key from: https://ai.google.dev/
# OpsGhost - Environment Variables
# Copy this file to .env.local and add your actual keys

# Get your Gemini API key from: https://aistudio.google.com/apikey
# It's FREE! No credit card required for testing.
GEMINI_API_KEY=your_gemini_api_key_hereyour_gemini_api_key_here

# Optional: Set development mode
NODE_ENV=development
